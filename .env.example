# ============================================================================
# Robil Trade — environment template.
# Copy ke `.env` lalu isi. JANGAN PERNAH commit `.env` (sudah di .gitignore).
# ============================================================================

# === Database ===
DATABASE_URL=postgresql+asyncpg://rtrade:rtrade@localhost:5432/rtrade
REDIS_URL=redis://localhost:6379/0

# === Data providers (read-only — TANPA permission trade, ADR-001) ===
TWELVEDATA_API_KEY=           # https://twelvedata.com free tier
FINNHUB_API_KEY=              # https://finnhub.io free tier
# ccxt Binance public data: TIDAK butuh API key

# === LLM ===
# ⚠️ HANYA API key RESMI (console.anthropic.com / aistudio.google.com /
# platform.openai.com). OAuth token langganan konsumen (mis. sk-ant-oat01-...)
# DILARANG dan DITOLAK oleh kode — melanggar ToS provider (PLAN §14.2).
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=             # opsional, untuk rotasi
ANTHROPIC_API_KEY_1=
OPENAI_API_KEY_1=             # opsional backup
# OpenRouter: satu key → 300+ model lintas provider; ambil di openrouter.ai/keys
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=         # opsional, untuk rotasi
OPENROUTER_API_KEY_3=         # opsional, untuk rotasi
LITELLM_MASTER_KEY=           # generate: openssl rand -hex 32
LITELLM_BASE_URL=http://localhost:4000

# === Delivery ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=             # chat user; bot hanya melayani ID ini

# === API ===
API_AUTH_TOKEN=               # bearer token utk POST /scan manual

# === ML model integrity (C3) ===
# REQUIRED untuk save/load model ML (HMM regime, meta-labeler). Kunci rahasia
# keyed-HMAC SHA-256; sidecar `.hmac` diverifikasi sebelum joblib.load (lawan
# pickle RCE). model_io fail CLOSED bila kosong — TANPA fallback plain-hash.
# JANGAN commit nilai. Generate: openssl rand -hex 32
MODEL_HMAC_KEY=

# === Runtime ===
ENV=dev                       # dev|prod
LOG_LEVEL=INFO

# --- OANDA market data (FX/metals primary). Free practice account + REST token. ---
# Create a demo (practice) account at oanda.com, then Manage API Access → generate token.
OANDA_ENV=practice            # practice | live
OANDA_TOKEN_1=
OANDA_ACCOUNT_1=
# Optional extra OANDA accounts for multi-account failover:
OANDA_TOKEN_2=
OANDA_ACCOUNT_2=
OANDA_TOKEN_3=
OANDA_ACCOUNT_3=
# Optional TwelveData fallback keys (used only if all OANDA legs fail):
TWELVEDATA_API_KEY_2=
TWELVEDATA_API_KEY_3=
