# ============================================================================
# Robil Trade — PRODUCTION environment template.
# Copy ke `.env` di VPS: scp .env.prod rtrade@robil-vps:/opt/robil-trade/.env
# JANGAN PERNAH commit file .env (sudah di .gitignore).
# chmod 600 .env setelah copy.
# ============================================================================

# === Database (internal Docker network) ===
RTRADE_DB_PASSWORD=                     # WAJIB: password kuat, generate: openssl rand -hex 24
DATABASE_URL=postgresql+asyncpg://rtrade:${RTRADE_DB_PASSWORD}@db:5432/rtrade
REDIS_URL=redis://redis:6379/0

# === Data providers (read-only — TANPA permission trade, ADR-001) ===
TWELVEDATA_API_KEY=                     # https://twelvedata.com
FINNHUB_API_KEY=                        # https://finnhub.io

# === LLM ===
# ⚠️ HANYA API key RESMI (console/aistudio). OAuth consumer token DILARANG (§14.2).
# Multi-key per provider = fallback otomatis saat kena rate limit (A1/A6).
GEMINI_API_KEY_1=                       # WAJIB minimal satu kredensial LLM
GEMINI_API_KEY_2=                       # Opsional: fallback
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
ANTHROPIC_API_KEY_1=                    # Opsional: critic/flagship upgrade
ANTHROPIC_API_KEY_2=
ANTHROPIC_API_KEY_3=
OPENAI_API_KEY_1=                       # Opsional: backup
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=
XAI_API_KEY_1=                          # Opsional: Grok (console.x.ai)
XAI_API_KEY_2=
XAI_API_KEY_3=

# Codex OAuth (langganan ChatGPT, Hermes-style Device Code Flow):
RTRADE_CODEX_CLIENT_ID=                 # Client ID untuk Codex OAuth (lihat docs/AUTH_OAUTH.md)
RTRADE_CODEX_TOKEN_URL=                 # Default: https://auth.openai.com/oauth/token
RTRADE_CODEX_DEVICE_AUTH_URL=           # Default: https://auth.openai.com/authorize/device

# xAI OAuth (langganan SuperGrok/X Premium+, Hermes-style Device Code Flow):
RTRADE_XAI_CLIENT_ID=                   # Client ID untuk xAI OAuth (lihat docs/AUTH_OAUTH.md)
RTRADE_XAI_TOKEN_URL=                   # Default: https://accounts.x.ai/oauth/token
RTRADE_XAI_DEVICE_AUTH_URL=             # Default: https://accounts.x.ai/oauth/authorize/device

# xAI Hermes-style external adapter (opsional):
RTRADE_XAI_AUTH_ADAPTER_BIN=
RTRADE_XAI_MODELS_URL=

# OAuth multi-akun (opsional, setara API key):
#   docker compose ... exec app python -m rtrade.cli.auth login --provider codex_oauth --account utama
#   docker compose ... exec app python -m rtrade.cli.auth login --provider xai_oauth --account cadangan
# Token tersimpan terenkripsi (RTRADE_TOKEN_KEY wajib di prod):
RTRADE_TOKEN_KEY=                       # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Di container prod, token disimpan di volume: RTRADE_TOKEN_DIR & RTRADE_ADC_DIR
# di-set oleh docker-compose.prod.yml (/app/data/auth/...). Jangan set di sini.

# === Delivery ===
TELEGRAM_BOT_TOKEN=                     # WAJIB: dari @BotFather
TELEGRAM_CHAT_ID=                       # WAJIB: chat ID user

# === API & Security ===
API_AUTH_TOKEN=                          # WAJIB: generate: openssl rand -hex 32
DOMAIN=                                  # Domain untuk TLS (kosong = localhost/HTTP only)

# === Runtime ===
ENV=prod
LOG_LEVEL=INFO
