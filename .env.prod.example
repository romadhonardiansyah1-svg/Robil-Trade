# ============================================================================
# Robil Trade — PRODUCTION environment template.
# Copy ke `.env` di VPS: scp .env.prod rtrade@robil-vps:/opt/robil-trade/.env
# JANGAN PERNAH commit file .env (sudah di .gitignore).
# chmod 600 .env setelah copy.
# ============================================================================

# === Database (internal Docker network) ===
RTRADE_DB_PASSWORD=                     # WAJIB: password kuat, generate: openssl rand -hex 24
DATABASE_URL=postgresql+asyncpg://rtrade:${RTRADE_DB_PASSWORD}@db:5432/rtrade
REDIS_URL=redis://redis:6379/0

# === Data providers (read-only — TANPA permission trade, ADR-001) ===
TWELVEDATA_API_KEY=                     # https://twelvedata.com
FINNHUB_API_KEY=                        # https://finnhub.io

# === LLM ===
# ⚠️ HANYA API key RESMI (console/aistudio). OAuth consumer token DILARANG (§14.2).
GEMINI_API_KEY_1=                       # WAJIB: key utama
GEMINI_API_KEY_2=                       # Opsional: rotasi multi-key
ANTHROPIC_API_KEY_1=                    # Opsional: critic upgrade
OPENAI_API_KEY_1=                       # Opsional: backup

# LITELLM_MASTER_KEY / LITELLM_BASE_URL tidak dipakai (LLM = library mode sejak F1).

# === Delivery ===
TELEGRAM_BOT_TOKEN=                     # WAJIB: dari @BotFather
TELEGRAM_CHAT_ID=                       # WAJIB: chat ID user

# === API & Security ===
API_AUTH_TOKEN=                          # WAJIB: generate: openssl rand -hex 32
DOMAIN=                                  # Domain untuk TLS (kosong = localhost/HTTP only)

# === Runtime ===
ENV=prod
LOG_LEVEL=INFO
