# ============================================================================
# Caddy Reverse Proxy — Robil Trade (D5)
# Deny by default, /health public, all other routes require bearer token.
# Ref: IMPLEMENTATION_PLAN §13
# ============================================================================

{$DOMAIN:localhost} {
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Publik: health saja.
    handle /health {
        reverse_proxy api:8000
    }

    # SEMUA route lain wajib bearer token.
    handle {
        @no_auth {
            not header Authorization "Bearer {$API_AUTH_TOKEN:changeme}"
        }
        respond @no_auth 401 {
            body "Unauthorized"
            close
        }
        reverse_proxy api:8000
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 50MiB
            roll_keep 5
        }
        format json
    }
}
