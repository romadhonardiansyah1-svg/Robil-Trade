# ============================================================================
# Caddy Reverse Proxy — Robil Trade (D5)
# Deny by default, /health public, all other routes require bearer token.
# Ref: IMPLEMENTATION_PLAN §13
# ============================================================================

{$DOMAIN:localhost} {
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Public: minimal liveness only. `handle /health` is an EXACT path match in
    # Caddy, so ONLY /health is public. /health/detail (and every other route)
    # falls through to the bearer-gated handle below (C4).
    handle /health {
        reverse_proxy api:8000
    }

    # SEMUA route lain wajib bearer token.
    handle {
        # C1: NO default token. If $API_AUTH_TOKEN is unset, Caddy substitutes an
        # empty string, so the matcher compares against `Bearer ` (empty) — no
        # real client token can match, and every request fails @no_auth -> 401.
        # Fail CLOSED: an unset var must NOT yield a usable default token.
        @no_auth {
            not header Authorization "Bearer {$API_AUTH_TOKEN}"
        }
        respond @no_auth 401 {
            body "Unauthorized"
            close
        }
        reverse_proxy api:8000
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 50MiB
            roll_keep 5
        }
        format json
    }
}
